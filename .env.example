# Discord Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_guild_id_here (optional for global commands)
OWNER_ID=your_discord_id_here

# Database
MONGODB_URI=mongodb://localhost:27017/market-ai
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Groq AI (Required - Get free key from https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=qwen/qwen3-32b

# Webhook (Optional - for logging)
WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url
WEBHOOK_SECRET=your_webhook_secret

# Server (Optional - for webhook receiver)
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# ProBot Credits Payment (Required - Discord user ID of the platform's ProBot account)
PROBOT_ACCOUNT_ID=your_probot_account_id_here

# ProBot Auto-Confirm (Optional - enables automatic payment confirmation)
AUTO_CONFIRM_ENABLED=false
AUTO_CONFIRM_POLL_INTERVAL=30000
AUTO_CONFIRM_MAX_PER_CYCLE=10

# ProBot API (Optional - for automatic transaction verification)
PROBOT_API_ENABLED=false
PROBOT_API_KEY=
PROBOT_API_URL=https://api.probot.io

# Webhook Server (Optional - port for REST API auto-confirm endpoint, leave empty to disable)
WEBHOOK_PORT=
WEBHOOK_SECRET=your_webhook_secret_here